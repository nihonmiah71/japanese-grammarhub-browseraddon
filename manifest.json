{
  "manifest_version": 3,
  "name": "Japanisch Grammatik Analyse Add-on (Serverlos)",
  "version": "1.1",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data/grammar_data.json", "data/patterns_data.json"],
      "matches": ["<all_urls>"]
    }
  ]
}